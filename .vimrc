syntax on
set t_Co=256
set whichwrap=b,s,h,l,<,>,[,],~

set mouse=a

set fenc=utf-8
set noswapfile
set showcmd
 
set number
set autoindent
set smartindent
set visualbell
set breakindent

hi DiffAdd    ctermfg=black ctermbg=2
hi DiffChange ctermfg=black ctermbg=3
hi DiffDelete ctermfg=black ctermbg=6
hi DiffText   ctermfg=black ctermbg=7
